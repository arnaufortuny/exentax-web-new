    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.6.1",
    "esbuild": "^0.27.3",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "i18next": "^25.8.18",
    "ioredis": "^5.10.1",
    "nanoid": "^5.1.6",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-icons": "^5.6.0",
