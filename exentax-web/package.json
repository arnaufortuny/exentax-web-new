    "audit:bundle": "node scripts/audit-bundle.mjs",
    "audit:bundle:fast": "node scripts/audit-bundle.mjs --no-build",
    "audit:bundle:diff": "node scripts/audit-bundle-diff.mjs",
    "test:bundle-diff-notify": "node scripts/audit-bundle-diff-notify-discord.test.mjs",
    "blog:validate-all": "node scripts/blog-validate-all.mjs",
    "seo:masterpiece-strict": "tsx scripts/blog-masterpiece-audit.mjs --strict",
    "lint:typography": "node scripts/check-typography-rule0.mjs",
    "lint:stray-reports": "node scripts/check-stray-reports.mjs",
    "lint:brand-casing": "node scripts/brand-casing-check.mjs",
    "lint:pt-pt": "node scripts/audit-pt-pt.mjs",
    "seo:check": "node scripts/seo-check-links.mjs",
    "seo:slash": "node scripts/seo-slash-hygiene.mjs",
    "seo:meta": "tsx scripts/seo/verify-meta.ts",
    "test:seo-check": "node scripts/seo-check-links.test.mjs",
    "test:seo-slash": "node scripts/seo-slash-hygiene.test.mjs",
    "i18n:validate": "tsx scripts/validate-i18n.ts",
    "i18n:generate-types": "tsx scripts/generate-i18n-types.ts",
    "i18n:check": "tsx scripts/generate-i18n-types.ts && tsx scripts/validate-i18n.ts",
    "lint:blog": "node scripts/blog-content-lint.mjs && node scripts/blog-cta-position-check.mjs && node scripts/blog-translation-quality-audit.mjs --check",
    "test:lint-blog": "node scripts/blog-content-lint.test.mjs",
    "test:orphan-detect": "node scripts/orphan-detect.test.mjs",
    "test:audit-faqs": "node scripts/audit-system-seo-faqs.test.mjs",
    "blog:final-qa": "node scripts/blog-final-qa.mjs",
    "blog:restructure": "node scripts/blog-restructure-non-es.mjs",
    "test:calculator": "tsx client/src/lib/calculator.test.ts",
    "test:newsletter": "tsx scripts/run-newsletter-e2e.ts",
    "test:booking": "tsx scripts/run-booking-e2e.ts",
    "test:discord-neon": "tsx scripts/test-discord-neon.ts",
    "discord:register": "tsx scripts/register-discord-commands.ts",
    "discord:register:dry": "tsx scripts/register-discord-commands.ts --dry-run",
    "discord:register:diff": "tsx scripts/register-discord-commands.ts --diff",
    "test:indexnow": "tsx server/indexnow.test.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
