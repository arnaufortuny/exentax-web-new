# Exentax — environment variables
# Copy to .env and fill in. Production startup is fail-fast for the REQUIRED block
# (see exentax-web/server/index.ts). Dev mode warns instead of crashing.

# ───────── REQUIRED in production ─────────
DATABASE_URL=postgresql://user:pass@host:5432/exentax
FIELD_ENCRYPTION_KEY=                       # 64 hex chars (32 bytes) for AES-256-GCM PII at rest
GOOGLE_SERVICE_ACCOUNT_KEY=                 # JSON string with service-account credentials (Calendar/Meet/Gmail)

# ───────── Discord (bot — required in production) ─────────
DISCORD_BOT_TOKEN=                          # Bot identity used for slash interactions and to deliver every notification
DISCORD_PUBLIC_KEY=                         # Application Ed25519 public key for /api/discord/interactions
DISCORD_APP_ID=                             # Application ID used to register slash commands at startup
DISCORD_GUILD_ID=                           # Guild whose member roles are checked for ADMIN_DISCORD_ROLE_ID
ADMIN_DISCORD_ROLE_ID=                      # Discord role ID gating every /agenda and /cita slash command
DISCORD_CHANNEL_REGISTROS=                  # #exentax-registros (lead/newsletter notifications; also fallback for #errores)
DISCORD_CHANNEL_AGENDA=                     # #exentax-agenda (booking lifecycle + bot interactive controls)
DISCORD_CHANNEL_CONSENTIMIENTOS=            # #exentax-consentimientos (GDPR consent log mirror)

# ───────── Optional Discord channels (fallback to REGISTROS) ─────────
DISCORD_CHANNEL_CALCULADORA=
DISCORD_CHANNEL_ACTIVIDAD=
DISCORD_CHANNEL_ERRORES=
DISCORD_CHANNEL_AUDITORIA=

# ───────── Operations ─────────
NODE_ENV=development
PORT=5000
LOG_LEVEL=info
DB_POOL_MAX=10
REDIS_URL=                                  # If set, used for distributed slot locks; otherwise in-memory
EXTRA_ALLOWED_ORIGINS=                      # Comma-separated extra CORS origins

# ───────── Google integrations ─────────
GOOGLE_CALENDAR_ID=                         # Defaults to primary calendar of the service account

# ───────── Branding / contact (used in emails, schema.org, footer) ─────────
SITE_URL=https://exentax.com
DOMAIN=exentax.com
COMPANY_ADDRESS_SHORT=
CONTACT_EMAIL=
LEGAL_EMAIL=
ADMIN_EMAIL=
WHATSAPP_NUMBER=
FACEBOOK_URL=
INSTAGRAM_URL=
LINKEDIN_URL=
TIKTOK_URL=
YOUTUBE_URL=

# ───────── SEO ─────────
INDEXNOW_KEY=
INDEXNOW_KEY_LOCATION=

# ───────── Frontend (must be prefixed VITE_) ─────────
VITE_GA4_ID=                                # Google Analytics 4 measurement ID, e.g. G-XXXXXXX
VITE_META_PIXEL_ID=                         # Meta (Facebook) pixel ID

# ───────── CI / build / E2E only (not used at runtime) ─────────
# BASE_URL=http://localhost:5000           # Override base URL for E2E test wrappers
# BUILD_ANALYZE=1                          # Enable bundle analyzer in scripts/build.ts
# SKIP_BUILD_E2E=1                         # Skip newsletter/booking e2e in scripts/build.ts (use on hosts where DB is unreachable at build time)
# NEWSLETTER_E2E_PORT=5051                 # Port for run-newsletter-e2e.ts
# BOOKING_E2E_PORT=5052                    # Port for run-booking-e2e.ts

# ──────────────────────────────────────────────────────────────────────
# OPTIONAL — SEO / indexing pipeline
# (server/google-indexing.ts, google-search-console.ts, sitemap-ping.ts,
#  scripts/seo-indexing-audit.mjs, scripts/seo-indexing-publish.mjs)
# ──────────────────────────────────────────────────────────────────────

# Public base URL used by sitemap, indexing pings, absolute meta links and
# E2E test wrappers. Default: derived from SITE_URL (https://exentax.com).
BASE_URL=

# Enable Google Indexing API submissions (requires GOOGLE_SERVICE_ACCOUNT_KEY).
# Set to `1` to enable; any other value (or unset) disables it. Default: off.
GOOGLE_INDEXING_API_ENABLE=

# Daily and per-run quota guardrails for the indexing pipeline.
# Defaults: 200 / 50 (server/google-indexing.ts).
GOOGLE_INDEXING_DAILY_QUOTA=
GOOGLE_INDEXING_MAX_PER_RUN=

# Disable Google Search Console submission entirely (`1` = off). Default:
# enabled whenever GOOGLE_SERVICE_ACCOUNT_KEY is present.
GOOGLE_SC_DISABLE=

# Override the GSC `siteUrl` property. Default: derived from BASE_URL/SITE_URL.
GOOGLE_SC_SITE_URL=

# Concurrency for the slash-policy / sitemap audit fetcher. Default: 8.
SEO_SITEMAP_CONCURRENCY=

# `1` = skip live HTTP probing in scripts/seo-stray-slash-redirect checks.
SEO_SLASH_SKIP_LIVE=

# Disable the periodic indexing audit cron entirely. Default: enabled.
INDEXING_AUDIT_DISABLE=

# Override which script the audit cron executes.
# Default: `scripts/seo-indexing-audit.mjs`.
INDEXING_AUDIT_SCRIPT=

# Where the audit writes its JSON reports + how many to retain.
# Defaults: `reports/indexing/` and 30.
INDEXING_REPORTS_DIR=
INDEXING_REPORTS_KEEP=

# ──────────────────────────────────────────────────────────────────────
# OPTIONAL — observability / runtime metadata
# (server/logger.ts, server/metrics.ts, server/index.ts)
# ──────────────────────────────────────────────────────────────────────

# `json` for structured logs (recommended in prod), `pretty` for dev.
# Default: pretty in dev, json in prod.
LOG_FORMAT=

# Bearer token gating GET /api/metrics. If unset, the endpoint is closed.
METRICS_TOKEN=

# Build-time identifier surfaced in /healthz and structured logs. Set by
# the deployer; unset locally is fine.
GIT_COMMIT=

# Replit deployment identifiers (set automatically by Replit; do NOT set
# manually). Listed here for documentation only.
REPL_DEPLOYMENT_ID=
REPLIT_DEPLOYMENT_ID=
