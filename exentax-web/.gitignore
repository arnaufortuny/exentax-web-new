# Google credentials — never commit real keys
# If you need to restore real credentials locally, copy them into this file
# but do NOT commit. The app reads from GOOGLE_SERVICE_ACCOUNT_KEY env var.
# server/google-credentials.ts

# Audit / Playwright outputs (regenerable, never tracked).
# Git won't list excluded directories, so to track specific files inside an
# ignored tree we have to re-include each path segment (same pattern as
# docs/audits/2026-04/conversion below).
reports/*
!reports/seo/
reports/seo/*
# Exception: the CTA / WhatsApp / navigation audit deliverables for
# Task #19 are committed so reviewers can open the final report and
# the supporting inventories/crawler outputs without re-running the
# generators. Refresh them with the four scripts in `scripts/cta-*.mjs`
# and `scripts/cta-whatsapp-audit.mjs` (see §5 of cta-audit-report.md).
!reports/README.md
!reports/cta-audit-report.md
!reports/cta-inventory.md
!reports/cta-inventory.csv
!reports/cta-inventory.json
!reports/cta-inventory-by-locale.csv
!reports/cta-inventory-by-locale.json
!reports/cta-crawler.md
!reports/cta-crawler.json
!reports/cta-rendered-crawler.md
!reports/cta-rendered-crawler.json
!reports/cta-rendered-inventory.csv
!reports/cta-rendered-inventory.json
!reports/cta-canonical.csv
!reports/cta-canonical.json
!reports/whatsapp-audit.md
!reports/whatsapp-inventory.csv
!reports/whatsapp-inventory.json
# Exception: the blog source-URL ping cache MUST be tracked. The structural
# validator (scripts/blog-sources-validate.mjs, rule 5) reads it offline in
# CI and fails critical if it is missing or older than 14 days. Refresh it
# with `node scripts/blog-verify-source-urls.mjs`.
!reports/seo/source-url-verification.json
# Exception: the SERP previews report (Task #4) is committed so reviewers
# can open the visual gallery without re-running the generator. Refresh it
# with `npx tsx scripts/seo/serp-previews.ts`.
!reports/seo/serp-previews/
reports/seo/serp-previews/*
!reports/seo/serp-previews/serp-previews.html
!reports/seo/serp-previews/serp-previews.md
!reports/seo/serp-previews/serp-previews.json
test-results/
.local-audit/
playwright-report/
blog-test.spec.ts
seo-meta-report.json

# Regenerable audit artifacts (scripts/audit-markdown-quality.mjs, etc.)
audits/
# Re-include the 2026-04 conversion audit deliverables (consumed by the
# downstream "Reescritura ES fallas" wave). Regenerable via
# scripts/audit-conversion-es-2026-04.mjs but pinned for cross-environment
# reproducibility. Git can't re-include files inside a fully ignored
# directory, so we have to un-ignore each segment of the parent path first.
!docs/audits/
docs/audits/*
!docs/audits/2026-04/
docs/audits/2026-04/*
!docs/audits/2026-04/conversion/
docs/audits/2026-04/conversion/*
!docs/audits/2026-04/conversion/*.md
!docs/audits/2026-04/conversion/*.json
