# Exentax — Environment variables
# Copy this file to `.env` and fill in real values for local dev.
# In production, the server is fail-fast: it refuses to boot if any
# variable marked REQUIRED is missing (see exentax-web/server/index.ts
# and exentax-web/server/db.ts).

# ──────────────────────────────────────────────────────────────────────
# REQUIRED (production refuses to boot without these)
# ──────────────────────────────────────────────────────────────────────

# PostgreSQL connection string (required in every environment).
DATABASE_URL=postgres://user:password@host:5432/exentax

# 64 hex chars / 32 bytes. Used by AES-256-GCM PII encryption at rest
# (exentax-web/server/field-encryption.ts). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FIELD_ENCRYPTION_KEY=

# Service-account JSON for Google Calendar / Google Meet event creation
# during the booking flow. Paste the full JSON on a single line.
GOOGLE_SERVICE_ACCOUNT_KEY=

# ──────────────────────────────────────────────────────────────────────
# Discord agenda BOT (replaces the legacy /admin web UI)
#
# All admin operations on the agenda (list, view, confirm, cancel,
# reschedule, no-show, manual emails, day blocking, manual booking
# creation) are exposed exclusively via the Discord bot — slash commands
# in `/ayuda`, `/agenda`, `/cita` plus the buttons / select menu under
# every #agenda notification. The legacy `/api/admin/*` REST surface
# and the `ADMIN_TOKEN` env var have been removed.
#
# When ANY of the four core vars below is missing, the interactions
# endpoint is not mounted and slash command sync is skipped (warning
# logged at startup). Notification channels (next block) are independent
# and degrade gracefully when their channel ID is unset.
# ──────────────────────────────────────────────────────────────────────

# Discord application ID (used to register global slash commands).
DISCORD_APP_ID=

# Bot token — used both inbound (signing follow-up REST calls) and
# outbound (publishing every notification + editing #agenda messages).
DISCORD_BOT_TOKEN=

# Application public key (64 hex chars / 32 raw bytes). Used to verify
# the Ed25519 signature Discord adds to every interaction payload.
DISCORD_PUBLIC_KEY=

# Discord role ID — only members carrying this role may invoke any
# slash command, click any agenda button or submit any modal.
ADMIN_DISCORD_ROLE_ID=

# ──────────────────────────────────────────────────────────────────────
# Discord notification channels (NO webhooks — bot REST API only)
#
# Each variable holds a Discord *channel ID* (right-click → Copy ID with
# developer mode on). The bot must be a member of every channel listed
# here with Send Messages + Embed Links + Read Message History.
# Missing channel IDs fall back to a no-op (warning logged); #errores
# falls back to #registros if unset so alerts never silently disappear.
# ──────────────────────────────────────────────────────────────────────
DISCORD_CHANNEL_REGISTROS=
DISCORD_CHANNEL_CALCULADORA=
DISCORD_CHANNEL_ACTIVIDAD=
DISCORD_CHANNEL_AGENDA=
DISCORD_CHANNEL_CONSENTIMIENTOS=
DISCORD_CHANNEL_ERRORES=
# #sistema-auditoria — every action triggered by the agenda bot
# (slash command, button or modal) is mirrored here for traceability.
DISCORD_CHANNEL_AUDITORIA=

# ──────────────────────────────────────────────────────────────────────
# OPTIONAL — runtime / infra
# ──────────────────────────────────────────────────────────────────────

# Express port (default 5000). Hostinger / la mayoría de PaaS la inyectan.
PORT=5000

# Si se define a 1, `npm run build` salta los e2e (newsletter, booking,
# no-show) que requieren DATABASE_URL durante la build. Útil en hostings
# donde la DB no está accesible en build time (Hostinger, etc.). En CI
# con DB conectada déjalo sin definir para que se ejecuten siempre.
SKIP_BUILD_E2E=

# Set to `production` to enable strict fail-fast checks and prod logging.
NODE_ENV=development

# `error` | `warn` | `info` | `debug`. Default: info in prod, debug in dev.
LOG_LEVEL=

# Postgres pool size. Default: 25 in prod, 10 in dev.
DB_POOL_MAX=

# Optional Redis. When set, rate-limit and lock stores switch from
# in-memory to Redis (exentax-web/server/rate-limit-store.ts and
# exentax-web/server/lock-store.ts).
REDIS_URL=

# Comma-separated extra origins added to the CORS allow-list
# (exentax-web/server/route-helpers.ts). Default origin list already
# covers exentax.com and the Replit dev domain.
EXTRA_ALLOWED_ORIGINS=

# Calendar used for Google Meet invites. Default: hola@exentax.com.
GOOGLE_CALENDAR_ID=

# IndexNow key for Bing/Yandex (exentax-web/server/indexnow.ts). Leave
# blank to skip IndexNow pings.
INDEXNOW_KEY=
INDEXNOW_KEY_LOCATION=

# ──────────────────────────────────────────────────────────────────────
# OPTIONAL — brand / contact constants (defaults are production-correct)
# All defined in exentax-web/server/server-constants.ts
# ──────────────────────────────────────────────────────────────────────
SITE_URL=https://exentax.com
DOMAIN=exentax.com
COMPANY_ADDRESS_SHORT=1209 Mountain Road Pl NE, Ste R · Albuquerque, NM 87110
CONTACT_EMAIL=hola@exentax.com
LEGAL_EMAIL=legal@exentax.com
ADMIN_EMAIL=arnau@exentax.com
WHATSAPP_NUMBER=34614916910
INSTAGRAM_URL=https://www.instagram.com/exentax.global/
TIKTOK_URL=https://www.tiktok.com/@exentax
YOUTUBE_URL=https://youtube.com/@exentax
FACEBOOK_URL=
LINKEDIN_URL=https://www.linkedin.com/company/exentax

# ──────────────────────────────────────────────────────────────────────
# OPTIONAL — frontend tracking (read via import.meta.env.* in the
# Vite client; must be prefixed VITE_ to be exposed to the browser).
# Defined in exentax-web/client/src/components/Tracking.tsx — leave
# blank to disable analytics in dev.
# ──────────────────────────────────────────────────────────────────────
VITE_GA4_ID=
VITE_META_PIXEL_ID=
